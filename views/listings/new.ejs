<% layout("/layouts/boilerplate")%>
<div class="row">
  <div class="col-8 offset-2">
    <br />
    <h3>Create a New listing</h3>
    <form
      method="post"
      action="/listings"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >
      <div class="mb-2">
        <label for="title" class="form-label">Enter Title</label>
        <input
          name="listings[title]"
          placeholder="Add a catchy title"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Title looks good!</div>
      </div>

      <div class="mb-2">
        <label for="description" class="form-label">Description</label>
        <textarea
          name="listings[description]"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter a short description</div>
      </div>

      <div class="mb-2">
        <label for="image" class="form-label">Upload Listing Image</label>
        <input
          name="listings[image]"
          type="file"
          class="form-control"
          required
        />
      </div>

      <div class="row">
        <div class="mb-2 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            name="listings[price]"
            placeholder="e.g. 2500 (per night)"
            type="number"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Price should be valid</div>
        </div>

        <div class="mb-2 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            name="listings[country]"
            placeholder="e.g. India"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">country name should be valid</div>
        </div>
      </div>

      <div class="mb-2">
        <label for="location" class="form-label"></label>
        <input
          name="listings[location]"
          placeholder="e.g. Goa, Baga Beach"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Location should be valid</div>
      </div>
      <br />
      <button class="btn btn-dark add-btn">Add</button>
      <br /><br />
    </form>
  </div>
</div>
